@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model GrandHotel.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Grand Hotel - Login</title>
    <!-- Bootstrap CSS CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    <style>
            body {
                background-color: #f4f7f6;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }

            .navbar-custom, .footer-custom {
                background-color: #031529;
                padding: 15px 0; 
            }

            .text-gold {
                color: #f1b434;
            }

            .btn-gold-outline {
                border: 1px solid #f1b434;
                color: #fff;
                font-weight: 600;
                font-size: 1.1rem;
            }

            .btn-gold-outline:hover {
                background-color: #f1b434;
                color: #031529;
            }

            .login-card {
                background: #ffffff;
                border-radius: 15px;
                box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.05);
                padding: 40px;
            }

            .btn-login {
                background-color: #0d6efd;
                color: white;
                border-radius: 8px;
                padding: 10px;
            }

                .btn-login:hover {
                    background-color: #0b5ed7;
                }

            .input-group-text {
                background-color: transparent;
                border-right: none;
            }

            .form-control-password {
                border-left: none;
                border-right: none;
            }

            .toggle-password {
                border-left: none;
                background-color: transparent;
                cursor: pointer;
            }
            
            .image-wrapper {
                max-width: 100%;
                height: auto;
                border-radius: 12px;
                overflow: hidden;
                box-shadow: 0px 4px 15px rgba(0,0,0,0.05);
                background: #fff;
                padding: 10px;
            }

            .brand-logo {
                max-height: 70px; 
                object-fit: contain;
            }

            
            .navbar-nav .nav-link {
                font-size: 1.15rem; 
                font-weight: 500;
                color: rgba(255, 255, 255, 0.85) !important;
                transition: color 0.3s ease; 
            }

                
            .navbar-nav .nav-link:hover {
                color: #f1b434 !important; 
            }


            .contact-admin-link {
                color: #0d6efd;
                font-weight: 600;
                text-decoration: none;
                transition: color 0.2s ease;
            }

                .contact-admin-link:hover {
                    color: #f1b434;
                    text-decoration: underline;
                }

            
            .footer-text {
                font-size: 1.15rem; 
            }

            .footer-icons a {
                font-size: 1.4rem; 
                color: rgba(255, 255, 255, 0.85);
                transition: color 0.2s ease;
            }

                .footer-icons a:hover {
                    color: #f1b434;
                }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

    <!-- Top Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand text-white fw-bold d-flex align-items-center" href="#">
                <img src="~/images/logo.png" alt="Grand Hotel Logo" class="brand-logo me-2" onerror="this.style.display='none'; document.getElementById('text-fallback').style.display='block';">
                <span id="text-fallback" style="display:none; font-size: 1.4rem;"><i class="fa-solid fa-hotel text-gold me-2"></i> Grand<span class="text-gold">Hotel</span></span>
            </a>

            <div class="collapse navbar-collapse justify-content-center">
                <ul class="navbar-nav gap-4">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Features">Features</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a></li>
                </ul>
            </div>
            <a asp-controller="Account" asp-action="Login" class="btn btn-gold-outline px-4">Login</a>
        </div>
    </nav>

    <!-- Main Content Container -->
    <div class="container my-auto py-5">
        <div class="row align-items-center g-5">

            <!-- Left Column: Illustration & Welcome Text -->
            <div class="col-lg-6 text-center text-lg-start">
                <h1 class="display-5 fw-bold text-dark mb-3">Welcome to Grand Hotel</h1>
                <p class="text-secondary fs-5 mb-4">A complete solution to manage your hotel operations efficiently and effectively.</p>

               
                <div class="d-flex justify-content-center justify-content-lg-start">
                    <div class="image-wrapper">

                        <img src="~/images/images.jpg" alt="Grand Hotel View" class="img-fluid rounded">
                    </div>
                </div>
            </div>

            <!-- Right Column: Login Form Card -->
            <div class="col-lg-5 offset-lg-1">
                <div class="login-card">
                    <h3 class="text-center fw-bold mb-1" style="color: #031529;">Grand Hotel Login</h3>
                    <div class="text-center mb-4 text-gold">
                        <span class="px-2">————</span> <i class="fa-solid fa-right-to-bracket"></i> <span class="px-2">————</span>
                    </div>

                    <form asp-action="Login" asp-controller="Account" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <!-- Email Field -->
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text text-muted"><i class="fa-regular fa-user"></i></span>
                                <input asp-for="Email" class="form-control" placeholder="Enter your email" style="border-left:none;" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- Password Field with Interactive eye toggler -->
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Password</label>
                            <div class="input-group">
                                <span class="input-group-text text-muted"><i class="fa-solid fa-lock"></i></span>
                                <input asp-for="Password" type="password" id="passwordInput" class="form-control form-control-password" placeholder="Enter your password" />
                                <!-- 2. Eye Icon wrapper -->
                                <span class="input-group-text toggle-password text-muted" id="togglePasswordBtn">
                                    <i class="fa-regular fa-eye" id="eyeIcon"></i>
                                </span>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <!-- Remember Me & Forgot Password -->
                        <div class="d-flex justify-content-between align-items-center mb-4 small">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label class="form-check-label text-secondary" asp-for="RememberMe">Remember me</label>
                            </div>
                            <a href="#" class="text-decoration-none" data-bs-toggle="modal" data-bs-target="#forgotPasswordModal">Forgot password?</a>
                        </div>

                        <button type="submit" class="btn btn-login w-100 fw-bold mb-3">Login</button>

                        <div class="text-center small text-secondary">
                            Don't have an account?
                            <a href="mailto:admin@grandhotel.com?subject=Hotel%20ERP%20Account%20Request" class="contact-admin-link">Contact Admin</a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>

    <!-- Bottom Footer -->
    <footer class="footer-custom text-white mt-auto">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center footer-text">
            <div class="d-flex align-items-center mb-2 mb-md-0">
                <img src="~/images/logo.png" alt="Grand Hotel Logo" class="brand-logo me-2" style="max-height: 35px;" onerror="this.style.display='none'; document.getElementById('footer-text-fallback').style.display='inline';">
                <span id="footer-text-fallback" style="display:none;" class="fw-bold">Grand<span class="text-gold">Hotel</span></span>
                <span class="ms-3 opacity-75">&copy; 2026 GrandHotel. All rights reserved.</span>
            </div>
            <div class="d-flex gap-4 footer-icons">
                <a href="#"><i class="fa-brands fa-facebook"></i></a>
                <a href="#"><i class="fa-brands fa-twitter"></i></a>
                <a href="#"><i class="fa-brands fa-linkedin"></i></a>
                <a href="#"><i class="fa-regular fa-envelope"></i></a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- 2. JavaScript logic for Password Show/Hide toggle -->
    <script>
            const passwordInput = document.getElementById('passwordInput');
            const togglePasswordBtn = document.getElementById('togglePasswordBtn');
            const eyeIcon = document.getElementById('eyeIcon');

            togglePasswordBtn.addEventListener('click', function () {
                // Check current input state
                if (passwordInput.type === 'password') {
                    passwordInput.type = 'text';
                    // Change icon to eye-slash
                    eyeIcon.classList.remove('fa-eye');
                    eyeIcon.classList.add('fa-eye-slash');
                } else {
                    passwordInput.type = 'password';
                    // Change icon back to normal eye
                    eyeIcon.classList.remove('fa-eye-slash');
                    eyeIcon.classList.add('fa-eye');
                }
            });
    </script>

    <div class="modal fade" id="forgotPasswordModal" tabindex="-1" aria-labelledby="forgotPasswordModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 12px;">
                <div class="modal-header" style="background-color: #031529; color: white; border-top-left-radius: 11px; border-top-right-radius: 11px;">
                    <h5 class="modal-title" id="forgotPasswordModalLabel"><i class="fa-solid fa-key text-gold me-2"></i> Reset Password</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center p-4">
                    <i class="fa-solid fa-user-shield text-secondary display-4 mb-3"></i>
                    <p class="fs-5 fw-bold text-dark">Security Notice</p>
                    <p class="text-secondary">For security reasons, password resets must be handled by the system administrator.</p>
                    <div class="alert alert-info small" role="alert">
                        Please contact your HR or IT Department to request a temporary password.
                    </div>
                </div>
                <div class="modal-footer" style="border-top: none;">
                    <button type="button" class="btn btn-secondary w-100" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
