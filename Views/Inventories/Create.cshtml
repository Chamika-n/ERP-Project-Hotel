@model GrandHotel.Models.Inventory

@{
    ViewData["Title"] = "Add Inventory Item";
}

@section Styles {
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}

<div class="main-area">
    <header class="topbar">
        <div class="page-heading">
            <h1>Add New Inventory Stock</h1>
            <p>Track new supply items, stock counts, and minimum thresholds.</p>
        </div>
    </header>

    <main class="content">
        <div class="management-card p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row g-3">
                    <!-- Item Name -->
                    <div class="col-md-6">
                        <label asp-for="ItemName" class="form-label">Item Name</label>
                        <input asp-for="ItemName" class="form-control" placeholder="E.g. Luxury Bath Towels" required />
                        <span asp-validation-for="ItemName" class="text-danger"></span>
                    </div>

                    <!-- Category (Dropdown එකක් කලා) -->
                    <div class="col-md-6">
                        <label asp-for="Category" class="form-label">Item Category</label>
                        <select asp-for="Category" class="form-select" required>
                            <option value="">Select Category</option>
                            <option value="Linen & Bedding">Linen & Bedding</option>
                            <option value="Toiletries & Amenities">Toiletries & Amenities</option>
                            <option value="Cleaning Supplies">Cleaning Supplies</option>
                            <option value="Kitchen Utensils">Kitchen Utensils</option>
                            <option value="F&B Stock">Food & Beverage Stock</option>
                        </select>
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>

                    <!-- Quantity -->
                    <div class="col-md-6">
                        <label asp-for="Quantity" class="form-label">Current Stock Quantity</label>
                        <input asp-for="Quantity" type="number" class="form-control" placeholder="150" required />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>

                    
                    <div class="col-md-6">
                        <label asp-for="MinimumStock" class="form-label">Minimum Alert Stock Level</label>
                        <input asp-for="MinimumStock" type="number" class="form-control" placeholder="20" required />
                        <span asp-validation-for="MinimumStock" class="text-danger"></span>
                    </div>

                    <!-- Unit Price -->
                    <div class="col-md-6">
                        <label asp-for="UnitPrice" class="form-label">Unit Price (LKR)</label>
                        <input asp-for="UnitPrice" type="number" class="form-control" placeholder="1250" required />
                        <span asp-validation-for="UnitPrice" class="text-danger"></span>
                    </div>

                    <!-- Supplier -->
                    <div class="col-md-6">
                        <label asp-for="Supplier" class="form-label">Supplier / Vendor Name</label>
                        <input asp-for="Supplier" class="form-control" placeholder="E.g. Tex Lanka Distributors" required />
                        <span asp-validation-for="Supplier" class="text-danger"></span>
                    </div>

                    <!-- Last Updated -->
                    <div class="col-md-6">
                        <label asp-for="LastUpdated" class="form-label">Restock Timestamp</label>
                        <input asp-for="LastUpdated" type="datetime-local" class="form-control" required />
                        <span asp-validation-for="LastUpdated" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-gold">
                        <i class="bi bi-box-seam-fill"></i> Add to Stock
                    </button>
                    <a asp-action="Index" class="btn btn-light">Cancel</a>
                </div>
            </form>
        </div>
    </main>
</div>