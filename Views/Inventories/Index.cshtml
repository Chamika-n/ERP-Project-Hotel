@model IEnumerable<GrandHotel.Models.Inventory>

@{
    ViewData["Title"] = "Inventory Stock Ledger";
}

@section Styles {
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}

<div class="main-area">
    <header class="topbar">
        <div class="page-heading">
            <h1>Inventory & Supplies</h1>
            <p>Monitor current warehouse levels, low stock alerts, and procurement prices.</p>
        </div>
    </header>

    <main class="content">
        <!-- Actions & Welcome Summary -->
        <section class="welcome-banner">
            <div>
                <span class="eyebrow">WAREHOUSE MANAGEMENT</span>
                <h2>Stock Levels Ledger</h2>
                <p>Prevent shortages by keeping an eye on critical alerts and automatically tracked item counts.</p>
            </div>
            <div class="banner-actions">
                <a asp-action="Create" class="btn btn-gold">
                    <i class="bi bi-box-seam-fill"></i> Add New Stock Item
                </a>
            </div>
        </section>

        <!-- Dynamic Stock Alerts Grid -->
        <section class="stats-grid mb-4" aria-label="Inventory statistics">
            <div class="stat-card">
                <div class="stat-icon total"><i class="bi bi-boxes"></i></div>
                <div>
                    <span>Total SKUs</span>
                    <strong>@Model.Count()</strong>
                    <small>Different items tracked</small>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon cleaning"><i class="bi bi-exclamation-triangle-fill"></i></div>
                <div>
                    <span>Low Stock Alerts</span>
                    
                    <strong>@Model.Count(i => i.Quantity <= i.MinimumStock)</strong>
                    <small class="text-danger">Needs urgent reorder</small>
                </div>
            </div>
        </section>

        <!-- Main Ledger Directory Card -->
        <section class="management-card">
            <div class="management-header">
                <div>
                    <h3>Stock Balances</h3>
                    <p>Real-time updates on active stock and utility allocations.</p>
                </div>
            </div>

            <div class="table-responsive room-table-wrap">
                <table class="table room-table align-middle">
                    <thead>
                        <tr>
                            <th>Item Details</th>
                            <th>Category</th>
                            <th class="text-center">Available Qty</th>
                            <th>Unit Cost</th>
                            <th>Supplier</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            
                            bool isLowStock = item.Quantity <= item.MinimumStock;

                            <tr class="@(isLowStock ? "table-danger-light" : "")">
                                <td>
                                    <strong>@item.ItemName</strong><br />
                                    <small class="text-muted">Last Restock: @item.LastUpdated.ToString("g")</small>
                                </td>
                                <td><span class="badge bg-light text-dark">@item.Category</span></td>
                                <td class="text-center">
                                    <strong class="@(isLowStock ? "text-danger" : "text-success")">@item.Quantity</strong>
                                    @if (isLowStock)
                                    {
                                        <br /><small class="badge bg-danger text-white px-1 py-0" style="font-size: 10px;">Low Stock (Min: @item.MinimumStock)</small>
                                    }
                                </td>
                                <td>@item.UnitPrice.ToString("C", new System.Globalization.CultureInfo("si-LK"))</td>
                                <td><small>@item.Supplier</small></td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Details" asp-route-id="item.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Delete" asp-route-id="item.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="management-footer">
                <span>Total tracked utility items: @Model.Count()</span>
            </div>
        </section>
    </main>
</div>