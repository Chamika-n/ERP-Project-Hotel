@model IEnumerable<GrandHotel.Models.Inventory>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

<form asp-action="Index" method="get" class="d-flex mb-3">
    <input type="text" name="searchString" class="form-control me-2" placeholder="Search by item name or category..." />
    <button type="submit" class="btn btn-primary">Search</button>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ItemName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Category)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Quantity)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MinimumStock)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UnitPrice)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Supplier)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LastUpdated)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.ItemName)
            </td>
            <td>
                @Html.DisplayFor(model => item.Category)
            </td>
             <td>
                    @Html.DisplayFor(model => item.Quantity)
                    @if (item.Quantity < item.MinimumStock)
                    {
                        <span class="badge bg-danger ms-2">🔴 Low Stock</span>
                    }
             </td>
            <td>
                @Html.DisplayFor(model => item.MinimumStock)
            </td>
            <td>
                @Html.DisplayFor(model => item.UnitPrice)
            </td>
            <td>
                @Html.DisplayFor(model => item.Supplier)
            </td>
            <td>
                @Html.DisplayFor(model => item.LastUpdated)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ItemId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ItemId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ItemId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
