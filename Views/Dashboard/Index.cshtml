@{
    ViewData["Title"] = "Main Dashboard";
}

<div class="card-custom">
    <h2 class="fw-bold mb-2" style="color: #031529;">Welcome to Grand Hotel Management Console</h2>
    <p class="text-secondary fs-5 mb-4">Select a module from the sidebar navigation panel to manage operational entries.</p>

    <div class="row g-4 mt-2">
        <div class="col-md-3">
            <div class="p-3 border-start border-primary border-4 rounded bg-light shadow-sm">     
                <p class="text-muted small fw-bold text-uppercase mb-1">Total Bookings</p>
                <h3 class="fw-bold m-0 text-dark">124</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 border-start border-success border-4 rounded bg-light shadow-sm">
                <p class="text-muted small fw-bold text-uppercase mb-1">Available Rooms</p>
                <h3 class="fw-bold m-0 text-dark">45 / 80</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 border-start border-warning border-4 rounded bg-light shadow-sm">
                <p class="text-muted small fw-bold text-uppercase mb-1">Pending Invoices</p>
                <h3 class="fw-bold m-0 text-dark">12</h3>
            </div>
        </div>
    </div>
</div>
