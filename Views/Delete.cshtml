@model GrandHotel.Models.Reservation

@{
    ViewData["Title"] = "Delete Reservation";
}

<div class="container mt-4">
    <h2>Delete Reservation</h2>
    <h3>Are you sure you want to delete this?</h3>
    <hr />
    <div>
        <dl class="row">
            <dt class="col-sm-3">Customer Name</dt>
            <dd class="col-sm-9">@Model.CustomerName</dd>

            <dt class="col-sm-3">Room Number</dt>
            <dd class="col-sm-9">@Model.RoomNumber</dd>

            <dt class="col-sm-3">Check-In</dt>
            <dd class="col-sm-9">@Model.CheckInDate.ToShortDateString()</dd>

            <dt class="col-sm-3">Check-Out</dt>
            <dd class="col-sm-9">@Model.CheckOutDate.ToShortDateString()</dd>

            <dt class="col-sm-3">Total Price</dt>
            <dd class="col-sm-9">@Model.TotalPrice</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
        </form>
    </div>
</div>