@model IEnumerable<GrandHotel.Models.Reservation>

@{
    ViewData["Title"] = "Reservations List";
}

<div class="container-fluid pt-4">
    <!-- Reservations List වගුව -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h2 class="mb-3 text-dark">Reservations List</h2>
            <p>
                <a asp-action="Create" class="btn btn-primary fw-bold">Create New Reservation</a>
            </p>

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Customer Name</th>
                            <th>Room Number</th>
                            <th>Check-In</th>
                            <th>Check-Out</th>
                            <th>Total Price</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.CustomerName)</td>
                                <td>@Html.DisplayFor(modelItem => item.RoomNumber)</td>
                                <td>@item.CheckInDate.ToShortDateString()</td>
                                <td>@item.CheckOutDate.ToShortDateString()</td>
                                <td>@Html.DisplayFor(modelItem => item.TotalPrice)</td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm mx-1">Edit</a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm mx-1">Details</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm mx-1">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // චාමිකගේ Sidebar එකේ තියෙන Reservations ලින්ක් එක සොයාගන්නවා
            let reservationLinks = document.querySelectorAll('a[href*="Reservation"]');

            reservationLinks.forEach(function(link) {
                // ඒ හැම ලින්ක් එකක්ම ඔයාගේ නිවැරදි පිටුවට හරවනවා
                link.setAttribute('href', '/Reservation/Index');
            });
        });
    </script>
}