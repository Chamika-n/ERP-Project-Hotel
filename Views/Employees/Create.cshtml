@model GrandHotel.Models.Employee

@{
    ViewData["Title"] = "Register Employee";
}

@section Styles {
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}

<div class="main-area">
    <header class="topbar">
        <div class="page-heading">
            <h1>Register New Staff Member</h1>
            <p>Add a new employee to the hotel management registry.</p>
        </div>
    </header>

    <main class="content">
        <div class="management-card p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row g-3">
                    <!-- Full Name -->
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label">Full Name</label>
                        <input asp-for="FullName" class="form-control" placeholder="E.g. John Doe" required />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <!-- NIC -->
                    <div class="col-md-6">
                        <label asp-for="NIC" class="form-label">NIC Number</label>
                        <input asp-for="NIC" class="form-control" placeholder="E.g. 199912345678 or 991234567V" required />
                        <span asp-validation-for="NIC" class="text-danger"></span>
                    </div>

                    <!-- Phone -->
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label">Phone Number</label>
                        <input asp-for="Phone" class="form-control" placeholder="E.g. 0771234567" required />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <!-- Email -->
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="johndoe@grandhotel.com" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- Position (Dropdown එකක් කලා) -->
                    <div class="col-md-6">
                        <label asp-for="Position" class="form-label">Job Position</label>
                        <select asp-for="Position" class="form-select" required>
                            <option value="">Select Position</option>
                            <option value="Manager">Manager</option>
                            <option value="Receptionist">Receptionist</option>
                            <option value="Housekeeper">Housekeeper</option>
                            <option value="Chef">Chef</option>
                            <option value="Security">Security</option>
                        </select>
                        <span asp-validation-for="Position" class="text-danger"></span>
                    </div>

                    <!-- Department (Dropdown එකක් කලා) -->
                    <div class="col-md-6">
                        <label asp-for="Department" class="form-label">Department</label>
                        <select asp-for="Department" class="form-select" required>
                            <option value="">Select Department</option>
                            <option value="Administration">Administration</option>
                            <option value="Front Office">Front Office</option>
                            <option value="Housekeeping">Housekeeping</option>
                            <option value="Kitchen & F&B">Kitchen & Food & Beverage</option>
                            <option value="Security">Security</option>
                        </select>
                        <span asp-validation-for="Department" class="text-danger"></span>
                    </div>

                    <!-- Salary -->
                    <div class="col-md-6">
                        <label asp-for="Salary" class="form-label">Basic Salary (LKR)</label>
                        <input asp-for="Salary" type="number" class="form-control" placeholder="55000" required />
                        <span asp-validation-for="Salary" class="text-danger"></span>
                    </div>

                    <!-- Join Date -->
                    <div class="col-md-6">
                        <label asp-for="JoinDate" class="form-label">Joined Date</label>
                        <input asp-for="JoinDate" type="date" class="form-control" required />
                        <span asp-validation-for="JoinDate" class="text-danger"></span>
                    </div>

                    <!-- Status (Dropdown එකක් කලා) -->
                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label">Employment Status</label>
                        <select asp-for="Status" class="form-select" required>
                            <option value="Active">Active</option>
                            <option value="On Leave">On Leave</option>
                            <option value="Suspended">Suspended</option>
                            <option value="Terminated">Terminated</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-gold">
                        <i class="bi bi-person-plus-fill"></i> Register Employee
                    </button>
                    <a asp-action="Index" class="btn btn-light">Cancel</a>
                </div>
            </form>
        </div>
    </main>
</div>