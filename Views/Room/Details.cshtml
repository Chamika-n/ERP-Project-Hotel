@model GrandHotel.Models.Room

@{
    ViewData["Title"] = "Room Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}

<div class="main-area">
    <header class="topbar">
        <div class="page-heading">
            <h1>Room Overview</h1>
            <p>Detailed specifications and status for Room @Model.RoomNumber.</p>
        </div>
    </header>

    <main class="content">
        <div class="management-card p-4">
            <div class="selected-room-panel mb-4">
                <div class="room-number-icon">
                    <i class="bi bi-door-open"></i>
                </div>
                <div>
                    <span>Room Number</span>
                    <strong>Room @Model.RoomNumber</strong>
                </div>
            </div>

            <table class="table table-bordered custom-table">
                <tbody>
                    <tr>
                        <th style="width: 30%;">Room Type</th>
                        <td>@Model.RoomType</td>
                    </tr>
                    <tr>
                        <th>Rate per Night</th>
                        <td>@Model.Price.ToString("C", new System.Globalization.CultureInfo("si-LK"))</td>
                    </tr>
                    <tr>
                        <th>Current Status</th>
                        <td>
                            <span class="badge @(Model.Status == "Available" ? "bg-success" : Model.Status == "Occupied" ? "bg-danger" : "bg-warning")">
                                @Model.Status
                            </span>
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="mt-4 d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-gold">
                    <i class="bi bi-pencil"></i> Edit Details
                </a>
                <a asp-action="Index" class="btn btn-light">Back to Directory</a>
            </div>
        </div>
    </main>
</div>