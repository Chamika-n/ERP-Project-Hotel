@model IEnumerable<GrandHotel.Models.Room>

@{
    ViewData["Title"] = "Room Management";
}

@section Styles {
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}

<div class="main-area">
    <header class="topbar">
        <div class="d-flex align-items-center gap-3">
            <div class="page-heading">
                <h1>Room Management</h1>
                <p>Monitor room availability, conditions and housekeeping status.</p>
            </div>
        </div>
    </header>

    <main class="content">
        <section class="welcome-banner">
            <div>
                <span class="eyebrow">GRAND HOTEL ERP</span>
                <h2>Room operations at a glance</h2>
                <p>Keep availability accurate, assign housekeeping priorities and update room conditions from one place.</p>
            </div>
            <div class="banner-actions">
                <a asp-action="Create" class="btn btn-gold">
                    <i class="bi bi-plus-lg"></i> Add New Room
                </a>
            </div>
        </section>

        <section class="stats-grid" aria-label="Room statistics">
            <article class="stat-card">
                <div class="stat-icon total"><i class="bi bi-building"></i></div>
                <div>
                    <span>Total Rooms</span>
                    <strong>@Model.Count()</strong>
                    <small>Registered in system</small>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-icon available"><i class="bi bi-check-circle-fill"></i></div>
                <div>
                    <span>Available</span>
                    <strong>@Model.Count(r => r.Status == "Available")</strong>
                    <small>Ready for reservation</small>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-icon occupied"><i class="bi bi-person-check-fill"></i></div>
                <div>
                    <span>Occupied</span>
                    <strong>@Model.Count(r => r.Status == "Occupied")</strong>
                    <small>Currently assigned</small>
                </div>
            </article>

            <article class="stat-card">
                <div class="stat-icon cleaning"><i class="bi bi-stars"></i></div>
                <div>
                    <span>Needs Attention</span>
                    <strong>@Model.Count(r => r.Status == "Cleaning" || r.Status == "Maintenance")</strong>
                    <small>Cleaning or maintenance</small>
                </div>
            </article>
        </section>

        <section class="management-card">
            <div class="management-header">
                <div>
                    <h3>Rooms Directory</h3>
                    <p>View and update room information and operational status.</p>
                </div>
            </div>

            <div class="table-responsive room-table-wrap">
                <table class="table room-table align-middle">
                    <thead>
                        <tr>
                            <th>Room</th>
                            <th>Type</th>
                            <th>Rate / Night</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.RoomNumber</strong></td>
                                <td>@item.RoomType</td>
                                <td>@item.Price.ToString("C", new System.Globalization.CultureInfo("si-LK"))</td>
                                <td>
                                    <span class="badge @(item.Status == "Available" ? "bg-success" : item.Status == "Occupied" ? "bg-danger" : "bg-warning")">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i> View</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="management-footer">
                <span>Showing @Model.Count() rooms</span>
            </div>
        </section>
    </main>
</div>