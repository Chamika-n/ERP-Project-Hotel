@{
    ViewData["Title"] = "Features & Amenities";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="display-4 fw-bold text-primary">Our Luxury Features</h2>
        <p class="lead text-muted">Discover the world-class services and amenities we offer at Grand Hotel.</p>
    </div>

    <div class="row g-4">
        <!-- Feature 1 -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 text-center p-3">
                <div class="card-body">
                    <h3 class="card-title h4 text-success mb-3"> Swimming Pool</h3>
                    <p class="card-text text-muted">Relax and unwind in our Olympic-sized infinity swimming pool with a stunning view.</p>
                </div>
            </div>
        </div>
        <!-- Feature 2 -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 text-center p-3">
                <div class="card-body">
                    <h3 class="card-title h4 text-success mb-3"> Fine Dining</h3>
                    <p class="card-text text-muted">Enjoy delicious local and international cuisines prepared by our world-class chefs.</p>
                </div>
            </div>
        </div>
        <!-- Feature 3 -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 text-center p-3">
                <div class="card-body">
                    <h3 class="card-title h4 text-success mb-3"> Luxury Spa & Gym</h3>
                    <p class="card-text text-muted">Stay fit and rejuvenated with our fully equipped modern gym and relaxing spa treatments.</p>
                </div>
            </div>
        </div>
    </div>
</div>
