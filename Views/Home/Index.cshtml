@{
    ViewData["Title"] = "Home Page";
}

<div class="p-5 mb-4 bg-dark text-white rounded-3 position-relative shadow"
     style="background: linear-gradient(rgba(3, 21, 41, 0.85), rgba(3, 21, 41, 0.85)), url('/images/hotel-bg.jpg') no-repeat center center; background-size: cover; min-height: 400px; display: flex; align-items: center;">
    <div class="container-fluid py-5 text-center">
        <h1 class="display-3 fw-bold text-warning mb-3">Welcome to Grand Hotel</h1>
        <p class="col-md-8 mx-auto fs-4 text-light opacity-90">
            Experience world-class luxury, elegant accommodations, and unparalleled hospitality in the heart of the city. Your perfect stay awaits.
        </p>
        <div class="mt-4">
            <a asp-controller="Account" asp-action="Login" class="btn btn-warning btn-lg px-5 fw-bold shadow-sm text-dark">
                <i class="fa-solid fa-right-to-bracket me-2"></i>Access ERP System
            </a>
        </div>
    </div>
</div>

<div class="container py-4">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-secondary">Why Choose Grand Hotel?</h2>
        <div class="mx-auto" style="width: 80px; height: 3px; background-color: #f1b434;"></div>
    </div>

    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 rounded-3">
                <div class="card-body">
                    <div class="text-warning display-4 mb-3">
                        <i class="fa-solid fa-bed"></i>
                    </div>
                    <h4 class="card-title fw-bold">Luxury Rooms</h4>
                    <p class="card-text text-muted">Stay in our meticulously designed smart suites with breathtaking ocean and city views.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 rounded-3">
                <div class="card-body">
                    <div class="text-warning display-4 mb-3">
                        <i class="fa-solid fa-bell-concierge"></i>
                    </div>
                    <h4 class="card-title fw-bold">24/7 Front Desk</h4>
                    <p class="card-text text-muted">Our dedicated concierge and room service teams are available round-the-clock to fulfill your needs.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 rounded-3">
                <div class="card-body">
                    <div class="text-warning display-4 mb-3">
                        <i class="fa-solid fa-map-location-dot"></i>
                    </div>
                    <h4 class="card-title fw-bold">Prime Location</h4>
                    <p class="card-text text-muted">Conveniently situated near major tourist attractions, business hubs, and the international airport.</p>
                </div>
            </div>
        </div>
    </div>
</div>